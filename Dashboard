      return '<div class="kat-madde-row"' + renkSt + '>\n' +
        '          <div><span class="kat-madde-no">' + no + '.</span>' +
        '<span class="kat-madde-ad">' + adKisa + '</span></div>\n' +
        '          <div class="kat-madde-cell kat-cell-evet">'  + (hasMaddeData ? (m.evet  > 0 ? m.evet  : '\u2013') : '\u2014') + '</div>\n' +
