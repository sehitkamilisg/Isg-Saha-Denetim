globalThis.formGonder = async function() {
  const okulAdiEl = document.getElementById('okulAdi');
  const secEl     = document.getElementById('okulSec');
  let okulAdi = (okulAdiEl?.value || '').trim();
  if (!okulAdi && secEl.value !== '' && okulListesi.length > 0) {
    const idx = parseInt(secEl.value);
    if (!isNaN(idx) && okulListesi[idx]) okulAdi = okulListesi[idx].ad;
  }
  if (!okulAdi) { toast('Lütfen okul adını girin veya listeden seçin', 't-warn'); return; }
  if (!document.getElementById('denetimTarihi').value) { toast('Lütfen denetim tarihini seçin', 't-warn'); return; }

  const hayir = Object.values(answers).filter(v => v === 'Hayır/Yok').length;
  const eksik = Object.values(answers).filter(v => v === 'Eksik').length;

  const katSayac = {A:0,B:0,C:0,D:0,E:0,F:0,G:0,H:0,I:0};
  Object.entries(answers).forEach(([no, val]) => {
    if (val !== 'Hayır/Yok' && val !== 'Eksik') return;
    const n = parseInt(no);
    if      (n <=  10) katSayac.A++;
    else if (n <=  21) katSayac.B++;
    else if (n <=  26) katSayac.C++;
    else if (n <=  31) katSayac.D++;
    else if (n <=  41) katSayac.E++;
    else if (n <=  57) katSayac.F++;
    else if (n <=  68) katSayac.G++;
    else if (n <=  98) katSayac.H++;
    else               katSayac.I++;
  });

  // Personel verileri topla
  const ptRows = document.querySelectorAll('.ptable tbody tr');
  const personel = {
    ogretmenK:  parseInt(ptRows[0]?.querySelectorAll('input')[0]?.value) || 0,
    ogretmenKS: parseInt(ptRows[0]?.querySelectorAll('input')[1]?.value) || 0,
    memuK:      parseInt(ptRows[1]?.querySelectorAll('input')[0]?.value) || 0,
    memuKS:     parseInt(ptRows[1]?.querySelectorAll('input')[1]?.value) || 0,
    hizmetliK:  parseInt(ptRows[2]?.querySelectorAll('input')[0]?.value) || 0,
    hizmetliKS: parseInt(ptRows[2]?.querySelectorAll('input')[1]?.value) || 0,
    guvenlikK:  parseInt(ptRows[3]?.querySelectorAll('input')[0]?.value) || 0,
    guvenlikKS: parseInt(ptRows[3]?.querySelectorAll('input')[1]?.value) || 0,
    digerK:     parseInt(ptRows[4]?.querySelectorAll('input')[0]?.value) || 0,
    digerKS:    parseInt(ptRows[4]?.querySelectorAll('input')[1]?.value) || 0,
    ogrenci:    parseInt(document.getElementById('ogrenciSayi')?.value) || 0,
    cirak:      parseInt(document.getElementById('cirakSayi')?.value)   || 0,
  };

  const formData = {
    action:        'submitForm',
    zaman:         new Date().toISOString(),
    okulAdi,
    okulAdres:     document.getElementById('okulAdres').value,
    mudurAdi:      document.getElementById('mudurAdi').value,
    mudurTel:      document.getElementById('mudurTel').value,
    tehlikeSinifi: selectedTehlike || 'Az Tehlikeli',
    denetimTarihi: document.getElementById('denetimTarihi').value,
    tespitler:     document.getElementById('tespitler').value,
    denetciAdi:    document.getElementById('denetciAdi').value,
    imzaMudur:     document.getElementById('imzaMudur').value,
    answers:       {...answers},
    photos:        Object.fromEntries(Object.entries(photos).map(([k,v]) => [k,v])),
    uygunsuzSayi:  hayir + eksik,
    personel,
  };

  const tur = okulTuruBulClient(okulAdi);

  document.getElementById('sending').classList.add('show');
  document.getElementById('sendingMsg').textContent = APPS_SCRIPT_URL
    ? 'Google Sheets\'e kaydediliyor…'
    : 'Yerel olarak kaydediliyor…';

  let docUrl = '', pdfUrl = '', sheetsMsg = '';

  if (APPS_SCRIPT_URL) {
    try {
      const resp = await fetch(APPS_SCRIPT_URL, {
        method:   'POST',
        redirect: 'follow',
        headers:  {'Content-Type': 'text/plain;charset=utf-8'},
        body:     JSON.stringify(formData)
      });
      const text = await resp.text();
      try {
        const data = JSON.parse(text);
        if (data.status === 'OK') {
          docUrl    = data.docUrl || '';
          pdfUrl    = data.pdfUrl || '';
          sheetsMsg = "✅ Google Sheets'e kaydedildi. " + (docUrl ? 'Rapor oluşturuldu.' : '');
        } else {
          sheetsMsg = 'Sheets yanıtı: ' + (data.mesaj || 'Bilinmeyen');
        }
      } catch(pe) {
        sheetsMsg = 'Google Sheets\'e gönderildi (yanıt okunamadı – normal).';
      }
    } catch(e) {
      sheetsMsg = '⚠️ Sheets bağlantı hatası (yerel kaydedildi): ' + e.message;
      console.error('Form gönderme hatası:', e);
    }
  } else {
    await new Promise(r => setTimeout(r, 800));
    sheetsMsg = '💾 Yalnızca yerel kaydedildi (Sheets URL girilmedi).';
  }

  document.getElementById('sending').classList.remove('show');

  // Dashboard'a ekle — answers'ı da sakla (akordiyonlu kategori detayı için)
  DENETIMLER.unshift({
    okul:     okulAdi,
    tarih:    formData.denetimTarihi.split('-').reverse().join('.'),
    tehlike:  selectedTehlike || 'Az Tehlikeli',
    tur, hayir, eksik,
    toplam:   hayir + eksik,
    uyg:      hayir + eksik,
    ebys:     '⏳ Bekliyor',
    raporUrl: docUrl,
    pdfUrl:   pdfUrl,
    arsivler: [],
    answers:  {...answers},
    kat:      katSayac,
    personel: {...personel},
  });

  document.getElementById('step9').style.display  = 'none';
  document.getElementById('successScreen').classList.add('show');
  document.getElementById('bnav').style.display   = 'none';
  document.getElementById('successLinks').innerHTML = [
    docUrl ? '<a class="s-link s-doc" href="' + (docUrl) + '" target="_blank">📄 Raporu Aç</a>'   : '',
    pdfUrl ? '<a class="s-link s-pdf" href="' + (pdfUrl) + '" target="_blank">📕 PDF İndir</a>' : ''
  ].join('');
  document.getElementById('successMsg').innerHTML = sheetsMsg + '<br><br>Dashboard güncellendi.';
  renderDash();
  toast('✅ Denetim kaydedildi', 't-ok');
}

