// ─ Tablo satırı HTML üretici ─
function _tabloSatirHtml(d) {
  const uyg       = (d.hayir||0) + (d.eksik||0);
  const pct       = (uyg / 138 * 100).toFixed(1);
  const arsivArr  = Array.isArray(d.arsivler) ? d.arsivler : [];
  const tumRaporlar = [
    ...arsivArr.map(a => ({ url: a.url, tarih: a.tarih || '' })),
    ...(d.raporUrl ? [{ url: d.raporUrl, tarih: 'Güncel', guncel: true }] : [])
  ];
  let linkler;
  if (tumRaporlar.length === 0) {
    linkler = '<span style="color:var(--mut);font-size:10px">–</span>';
  } else if (tumRaporlar.length === 1) {
    const r = tumRaporlar[0];
    linkler = '<a class="tbl-link" href="' + r.url + '" target="_blank">' + (r.guncel ? '📄 Rapor' : '📄 Rapor (Arş.)') + '</a>';
  } else {
    linkler = '<div style="display:flex;flex-wrap:wrap;gap:4px;align-items:center">' +
      tumRaporlar.map(function(r,i) {
        const no    = i + 1;
        const son   = i === tumRaporlar.length - 1;
        const etiket = son ? '📄 R' + no + ' ✓' : '📄 R' + no;
        const renk   = son ? 'var(--teal)' : 'var(--mut2)';
        const title  = son ? 'Güncel Rapor' : ('Arşiv #' + no + (r.tarih ? ' – ' + r.tarih : ''));
        return '<a class="tbl-link" href="' + r.url + '" target="_blank" title="' + title + '" style="color:' + renk + ';font-size:11px;white-space:nowrap">' + etiket + '</a>';
      }).join('') + '</div>';
  }
  const ebysBadge = (d.ebys||'').includes('Kapatıldı')
    ? '<span class="badge b-kap">✅ Kapatıldı</span>'
    : '<span class="badge b-bek">' + (d.ebys||'⏳ Bekliyor') + '</span>';
  const okulEnc  = encodeURIComponent(d.okul);
  const tarihEnc = encodeURIComponent(d.tarih||'');
  const silBtn   = '<button class="btn-sil-satir" onclick="denetimSilBaslatEnc(\'' + okulEnc + '\',\'' + tarihEnc + '\')" title="Bu denetimi sil">🗑️</button>';
  return '<tr>' +
    '<td>' + (d.okul.length>36?d.okul.substring(0,36)+'…':d.okul) + '</td>' +
    '<td style="color:' + (TUR_RENK[d.tur]||'#64748b') + ';font-weight:600">' + (d.tur||'–') + '</td>' +
    '<td>' + (d.tarih||'–') + '</td>' +
    '<td><span class="badge ' + (d.tehlike==='Tehlikeli'||d.tehlike==='Çok Tehlikeli'?'b-teh':'b-az') + '">' + (d.tehlike||'–') + '</span></td>' +
    '<td style="font-family:Arial Black,sans-serif;font-weight:700;color:' + (uyg>=30?'#f87171':uyg>=10?'#fbbf24':'#34d399') + '">' + uyg + ' <span style="font-size:10px;color:var(--mut)">(%' + pct + ')</span></td>' +
    '<td>' + ebysBadge + '</td>' +
    '<td>' + linkler + '</td>' +
    '<td style="text-align:center;padding:4px 6px">' + silBtn + '</td>' +
  '</tr>';
}

globalThis.tabloRender = function() {
  // İlk 5'i risk skoru (uyg%) büyükten küçüğe göster
  tablo5TumVeri = [...tabloTumVeri].sort((a,b) => {
    const pA = ((a.hayir||0)+(a.eksik||0)) / 138;
    const pB = ((b.hayir||0)+(b.eksik||0)) / 138;
    return pB - pA;
  });
  const ilk5 = tablo5TumVeri.slice(0, 5);

  document.getElementById('tabloBody').innerHTML =
    ilk5.map(d => _tabloSatirHtml(d)).join('')
    || '<tr><td colspan="8" style="text-align:center;color:var(--mut);padding:18px">Veri yok</td></tr>';

  const footer = document.getElementById('tabloFooter');
  const metaEl = document.getElementById('tabloTop5Meta');
  const gizli  = tabloTumVeri.length - 5;
  if (footer) footer.style.display = tabloTumVeri.length > 5 ? 'flex' : 'none';
  if (metaEl) metaEl.textContent   = tabloTumVeri.length > 5
    ? 'En riskli 5 gösteriliyor · ' + gizli + ' denetim gizli'
    : tabloTumVeri.length + ' denetim';
}

