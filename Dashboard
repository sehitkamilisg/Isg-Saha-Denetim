// Tarih string'ini (GG.AA.YYYY) input[type=date] formatına (YYYY-MM-DD) çevir
globalThis._tarihInputFormat = function(tarihStr) {
  if (!tarihStr) return '';
  // GG.AA.YYYY → YYYY-MM-DD
  const parts = String(tarihStr).split('.');
  if (parts.length === 3) {
    return parts[2] + '-' + parts[1].padStart(2,'0') + '-' + parts[0].padStart(2,'0');
  }
  // Zaten YYYY-MM-DD formatındaysa olduğu gibi dön
  if (/^\d{4}-\d{2}-\d{2}$/.test(tarihStr)) return tarihStr;
  return '';
};

