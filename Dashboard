    ctx.beginPath(); ctx.moveTo(x30, padTop); ctx.lineTo(x30, cnv.height-padBot); ctx.stroke();
    ctx.setLineDash([]);
    // Barlar
    siraliBuyuk.forEach(function(d, i) {
      const y   = padTop + i * rowH;
      const pct = Math.min(d.pct, 55);
