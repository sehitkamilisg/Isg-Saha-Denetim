globalThis.denetimSilBaslatEnc = function(okulEnc, tarihEnc) {
  denetimSilBaslat(decodeURIComponent(okulEnc), decodeURIComponent(tarihEnc));
};

globalThis.denetimSilBaslat = function(okulAdi, tarih) {
  _silHedefOkul  = okulAdi;
  _silHedefTarih = tarih || '';

  // Modal içeriğini doldur
  const okulEl = document.getElementById('silModalOkul');
  if (okulEl) okulEl.textContent = okulAdi + (tarih ? '  ·  ' + tarih : '');

  const onayBtn = document.getElementById('silOnaylaBtn');
  if (onayBtn) {
    onayBtn.disabled    = false;
    onayBtn.textContent = '🗑️ Evet, Sil';
  }

  document.getElementById('silModalBg').classList.add('show');
};

globalThis.silModalKapat = function() {
  document.getElementById('silModalBg').classList.remove('show');
  _silHedefOkul  = '';
  _silHedefTarih = '';
};

globalThis.silOnaylaKlikla = function() {
  if (!_silHedefOkul) { silModalKapat(); return; }

  const onayBtn = document.getElementById('silOnaylaBtn');
  if (onayBtn) {
    onayBtn.disabled   = true;
    onayBtn.innerHTML  = '<span class="sil-spinner"></span>Siliniyor…';
  }

  const payload = {
    action       : 'denetimSil',
    okulAdi      : _silHedefOkul,
    denetimTarihi: _silHedefTarih
  };

  fetch(APPS_SCRIPT_URL, {
    method  : 'POST',
    headers : { 'Content-Type': 'text/plain' },
    body    : JSON.stringify(payload)
  })
  .then(r => r.json())
  .then(data => {
    silModalKapat();
    if (data.status === 'OK') {
      const silinenOkul = data.okulAdi || _silHedefOkul;
      toast('✅ Denetim silindi: ' + silinenOkul, 't-ok');
      // Yerel veri yapılarından da anında kaldır
      _denetimLocaldenKaldir(silinenOkul, data.tarih || _silHedefTarih);
      // Dashboard'u yeniden çiz (senkronizasyon gerekmez)
      renderDash();
    } else {
      toast('❌ Silme hatası: ' + (data.mesaj || 'Bilinmeyen hata'), 't-err');
      const ob = document.getElementById('silOnaylaBtn');
      if (ob) { ob.disabled = false; ob.textContent = '🗑️ Evet, Sil'; }
    }
  })
  .catch(err => {
    silModalKapat();
    toast('❌ Bağlantı hatası: ' + err.message, 't-err');
  });
};

// Yerel veri dizisinden kaydı kaldır (okul adı + tarih eşleşmesi)
function _denetimLocaldenKaldir(okulAdi, tarih) {
  try {
    // Ana veri kaynağı: DENETIMLER global dizisi
    if (typeof DENETIMLER !== 'undefined' && Array.isArray(DENETIMLER)) {
      const onceki = DENETIMLER.length;
      for (let i = DENETIMLER.length - 1; i >= 0; i--) {
        const d = DENETIMLER[i];
        const okulEslesiyor  = (d.okul  || '').toLowerCase().trim() === okulAdi.toLowerCase().trim();
        const tarihEslesiyor = !tarih   || !d.tarih || d.tarih === tarih;
        if (okulEslesiyor && tarihEslesiyor) {
          DENETIMLER.splice(i, 1);
          break; // Sadece ilk eşleşeni kaldır
        }
      }
      console.log('DENETIMLER güncellendi: ' + onceki + ' → ' + DENETIMLER.length);
    }
  } catch(e) {
    console.warn('Yerel veri güncelleme uyarısı:', e);
  }
}

