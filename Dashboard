/* Toast bildirimi */
.toast{
  position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);
  background:#1a2336;border:1px solid var(--bdr);color:var(--txt);
  padding:10px 20px;border-radius:12px;font-size:13px;font-weight:600;
  z-index:9999;transition:transform .3s;white-space:nowrap;
  box-shadow:0 8px 30px rgba(0,0,0,.5);
}
.toast.show{transform:translateX(-50%) translateY(0);}
.toast.t-ok{border-color:rgba(52,211,153,.4);color:var(--green);}
.toast.t-err{border-color:rgba(248,113,113,.4);color:var(--red);}
.toast.t-warn{border-color:rgba(251,191,36,.4);color:var(--amber);}

.tbl-link{color:var(--teal);text-decoration:none;font-size:11px;transition:opacity .15s;}
