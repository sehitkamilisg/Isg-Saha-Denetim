  if (footer)  footer.style.display  = riskTumVeri.length > 5 ? 'flex' : 'none';
  if (metaEl)  metaEl.textContent    = riskTumVeri.length > 5
    ? 'İlk 5 gösteriliyor · ' + gizli + ' okul gizli'
