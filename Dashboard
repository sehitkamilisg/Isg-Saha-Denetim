globalThis._tabloDrawerRender = function() {
  const arama  = (document.getElementById('tabloDrawerArama')?.value||'').toLowerCase().trim();
  const filtre = arama
    ? tablo5TumVeri.filter(d => (d.okul||'').toLowerCase().includes(arama))
    : tablo5TumVeri;
  const toplamSayfa = Math.ceil(filtre.length / TABLO_SAYFA_BOYUT);
  if (tabloDrwSayfa >= toplamSayfa) tabloDrwSayfa = Math.max(0, toplamSayfa-1);
  const bas     = tabloDrwSayfa * TABLO_SAYFA_BOYUT;
  const gorunen = filtre.slice(bas, bas + TABLO_SAYFA_BOYUT);

  const body = document.getElementById('tabloDrawerBody');
  if (body) {
    body.innerHTML = gorunen.map(d => _tabloSatirHtml(d)).join('')
      || '<tr><td colspan="8" style="text-align:center;color:var(--mut);padding:20px">Sonuç bulunamadı</td></tr>';
  }
  _drawerSayfalama('tabloDrawerSayfa', toplamSayfa, tabloDrwSayfa, 'tabloDrwSayfaDegis');
}
globalThis.tabloDrwSayfaDegis = function(val, mutlak) {
  const arama  = (document.getElementById('tabloDrawerArama')?.value||'').toLowerCase().trim();
  const filtre = arama ? tablo5TumVeri.filter(d=>(d.okul||'').toLowerCase().includes(arama)) : tablo5TumVeri;
  const toplamSayfa = Math.ceil(filtre.length / TABLO_SAYFA_BOYUT);
  tabloDrwSayfa = mutlak ? val : Math.max(0, Math.min(toplamSayfa-1, tabloDrwSayfa+val));
  _tabloDrawerRender();
  document.querySelector('#tabloDrawerBg .drawer-body').scrollTop = 0;
}

// ─ Ortak drawer sayfalama yardımcısı ─
globalThis._drawerSayfalama = function(elId, toplamSayfa, aktifSayfa, fnAdi) {
  const el = document.getElementById(elId);
  if (!el) return;
  if (toplamSayfa <= 1) { el.innerHTML = ''; return; }
  const btnStil = (aktif) =>
    'style="padding:5px 11px;border-radius:8px;border:1px solid ' +
    (aktif?'rgba(56,189,248,.5)':'var(--bdr)') + ';background:' +
    (aktif?'rgba(56,189,248,.15)':'transparent') + ';color:' +
    (aktif?'var(--teal)':'var(--mut2)') +
    ';font-size:12px;font-weight:700;cursor:pointer;font-family:Arial,sans-serif;"';
  let html = '<button onclick="' + fnAdi + '(-1)" ' + btnStil(false) + '>←</button>';
  for (let i = 0; i < toplamSayfa; i++) {
    if (toplamSayfa > 7 && Math.abs(i-aktifSayfa) > 2 && i !== 0 && i !== toplamSayfa-1) {
      if (i===1||i===toplamSayfa-2) html += '<span style="color:var(--mut);padding:0 4px">…</span>';
      continue;
    }
    html += '<button onclick="' + fnAdi + '(' + i + ',true)" ' + btnStil(i===aktifSayfa) + '>' + (i+1) + '</button>';
  }
  html += '<button onclick="' + fnAdi + '(1)" ' + btnStil(false) + '>→</button>';
  el.innerHTML = html;
}

