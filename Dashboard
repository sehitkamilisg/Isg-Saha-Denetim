::-webkit-scrollbar{width:4px;} ::-webkit-scrollbar-track{background:var(--bg);} ::-webkit-scrollbar-thumb{background:var(--sur2);border-radius:2px;}

/* Sync spinner */
.sync-spin{display:none;width:14px;height:14px;border:2px solid rgba(52,211,153,.3);border-top-color:var(--green);border-radius:50%;animation:spin 1s linear infinite;flex-shrink:0;}
.sync-spin.show{display:inline-block;}
@keyframes spin{to{transform:rotate(360deg)}}

/* ═══ FORM OVERLAY ═══ */
.overlay{display:none!important;visibility:hidden;position:fixed;inset:0;z-index:1000;background:rgba(5,10,20,.88);backdrop-filter:blur(6px);}
