globalThis._riskDrawerRender = function() {
  const arama = (document.getElementById('riskDrawerArama')?.value || '').toLowerCase().trim();
  const filtre = arama
    ? riskTumVeri.filter(d => (d.okul||'').toLowerCase().includes(arama))
    : riskTumVeri;
  const toplamSayfa = Math.ceil(filtre.length / RISK_SAYFA_BOYUT);
  if (riskDrwSayfa >= toplamSayfa) riskDrwSayfa = Math.max(0, toplamSayfa-1);
  const bas = riskDrwSayfa * RISK_SAYFA_BOYUT;
  const gorunen = filtre.slice(bas, bas + RISK_SAYFA_BOYUT);

  const listEl = document.getElementById('riskDrawerList');
  if (listEl) {
    listEl.innerHTML = gorunen.map((d,i) => _riskSatirHtml(d, bas+i+1)).join('')
      || '<div style="padding:20px;text-align:center;color:var(--mut);font-size:12px">Sonuç bulunamadı</div>';
  }
  _drawerSayfalama('riskDrawerSayfa', toplamSayfa, riskDrwSayfa, 'riskDrwSayfaDegis');
}
globalThis.riskDrwSayfaDegis = function(val, mutlak) {
  const arama = (document.getElementById('riskDrawerArama')?.value||'').toLowerCase().trim();
  const filtre = arama ? riskTumVeri.filter(d=>(d.okul||'').toLowerCase().includes(arama)) : riskTumVeri;
  const toplamSayfa = Math.ceil(filtre.length / RISK_SAYFA_BOYUT);
  riskDrwSayfa = mutlak ? val : Math.max(0, Math.min(toplamSayfa-1, riskDrwSayfa+val));
  _riskDrawerRender();
  document.querySelector('#riskDrawerBg .drawer-body').scrollTop = 0;
}
