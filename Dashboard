      // Arka plan çizgisi
      ctx.fillStyle = '#e2e8f0';
      ctx.fillRect(padL, y+6, barW, rowH-12);
      // Bar
      ctx.fillStyle = clr;
      ctx.fillRect(padL, y+6, bw, rowH-12);
      // Bar içi beyaz ışık
      ctx.fillStyle = 'rgba(255,255,255,0.18)';
