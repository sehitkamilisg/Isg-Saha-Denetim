// ── Önce doğrudan fetch dene, CORS hatası alırsa
//    script tag JSONP trick'ini dene (Apps Script destekler)
// ════════════════════════════════════════════════
// JSONP yardımcı — file:// protokolünden CORS olmadan çalışır
function _jsonpFetch(url) {
  return new Promise(function(resolve, reject) {
    var cbName = '__isgCb_' + Date.now();
    var script = document.createElement('script');
    var done = false;
    var timer = setTimeout(function() {
      if (!done) { done = true; delete window[cbName]; script.remove();
        reject(new Error('Zaman aşımı — Apps Script URL ve dağıtım ayarlarını kontrol edin')); }
    }, 12000);
    window[cbName] = function(data) {
      if (!done) { done = true; clearTimeout(timer); delete window[cbName]; script.remove(); resolve(data); }
    };
    script.onerror = function() {
      if (!done) { done = true; clearTimeout(timer); delete window[cbName]; script.remove();
        reject(new Error('Bağlantı hatası — URL doğru mu ve dağıtım "Erişim: Herkes" mi?')); }
    };
    script.src = url + '&callback=' + cbName;
    document.head.appendChild(script);
  });
}

globalThis.sheettenSenkronize = async function() {
  if (!APPS_SCRIPT_URL) { toast('Önce Apps Script URL\'si girin ve kaydedin', 't-warn'); return; }

  var spin    = document.getElementById('syncSpin');
  var syncBtn = document.getElementById('syncBtn');
  var status  = document.getElementById('cfgStatus');
  spin.classList.add('show');
  syncBtn.disabled = true;
  status.className  = 'cfg-status warn';
  status.textContent = '🔄 Bağlanıyor…';

  var buildUrl = function(action) {
    return APPS_SCRIPT_URL + (APPS_SCRIPT_URL.includes('?') ? '&' : '?') + 'action=' + action + '&t=' + Date.now();
  };

  try {
    var data = null;
    // Önce fetch dene; başarısız veya JSON parse edilemezse JSONP'ye geç
    // (GitHub Pages gibi farklı origin'den erişimde fetch CORS/redirect sorunu yaşayabilir)
    try {
      var resp = await fetch(buildUrl('getDenetimler'), { method: 'GET', redirect: 'follow' });
      if (resp.ok) {
        var text = await resp.text();
        try { data = JSON.parse(text); } catch(pe) {
          // Yanıt HTML/boş geldi (redirect sonrası) — JSONP'ye geç
          console.warn('Fetch yanıtı JSON değil, JSONP deneniyor.');
          data = await _jsonpFetch(buildUrl('getDenetimler'));
        }
      } else {
        console.warn('Fetch HTTP ' + resp.status + ', JSONP deneniyor.');
        data = await _jsonpFetch(buildUrl('getDenetimler'));
      }
    } catch(fetchErr) {
      console.warn('Fetch başarısız, JSONP deneniyor:', fetchErr.message);
      data = await _jsonpFetch(buildUrl('getDenetimler'));
    }

    if (!data) throw new Error('Veri alınamadı');

    if (data.status === 'OK' && Array.isArray(data.denetimler)) {
      DENETIMLER = data.denetimler.map(d => {
        const hayir = parseInt(d.hayir) || 0;
        const eksik = parseInt(d.eksik) || 0;
        const uyg   = hayir + eksik || parseInt(d.uyg) || 0;
        return {
          okul:         d.okul         || '',
          tur:          d.tur          || okulTuruBulClient(d.okul) || 'Diğer',
          tarih:        d.tarih        || '',
          tehlike:      d.tehlike      || 'Az Tehlikeli',
          hayir,
          eksik,
          toplam:       uyg,
          uyg,
          giderilen:    parseInt(d.giderilen) || 0,
          kalan:        parseInt(d.kalan)  >= 0 ? parseInt(d.kalan)  : uyg,
          yazıNo:       d.yazıNo       || '',
          ebysTarih:    d.ebysTarih    || '',
          ebys:         d.ebys         || '⏳ Bekliyor',
          cevapTarih:   d.cevapTarih   || '',
          cevap:        d.cevap        || '⏳ Bekleniyor',
          cevapNot:     d.cevapNot     || '',
          kapatmaTarih: d.kapatmaTarih || '',
          durum:        d.durum        || '',
          notlar:       d.notlar       || '',
          raporUrl:     d.raporUrl     || '',
          arsivler:     Array.isArray(d.arsivler) ? d.arsivler : [],
          answers:      d.answers      || null,
          kat:          d.kat          || {A:0,B:0,C:0,D:0,E:0,F:0,G:0,H:0,I:0},
          personel:     d.personel     || null,
        };
      });
      renderDash();
      status.className  = 'cfg-status ok';
      status.textContent = '✅ ' + DENETIMLER.length + ' kayıt';
      toast('✅ ' + DENETIMLER.length + ' denetim yüklendi', 't-ok');
      document.getElementById('corsInfo').classList.remove('show');
    } else {
      throw new Error(data.mesaj || 'Bilinmeyen hata');
    }
  } catch(e) {
    status.className  = 'cfg-status err';
    status.textContent = '❌ Bağlantı Hatası';
    document.getElementById('corsInfo').classList.add('show');
    toast('Hata: ' + e.message, 't-err');
    console.error('Senkronize hatası:', e);
  } finally {
    spin.classList.remove('show');
    syncBtn.disabled = false;
  }
}

// JSONP yardımcı — Apps Script callback parametresini destekler
globalThis.jsonpFetch = function(url) {
  return new Promise((resolve, reject) => {
    const cbName = '__isgCb_' + Date.now();
    const script = document.createElement('script');
    let done = false;

    window[cbName] = function(data) {
      done = true;
      delete window[cbName];
      script.remove();
      resolve(data);
    };

    script.src     = url + '&callback=' + cbName;
    script.onerror = () => {
      if (!done) {
        delete window[cbName];
        script.remove();
        reject(new Error('JSONP yüklenemedi. Apps Script "Erişim: Herkes" olarak dağıtılmalı.'));
      }
    };
    // 8 saniye timeout
    setTimeout(() => {
      if (!done) {
        delete window[cbName];
        script.remove();
        reject(new Error('Zaman aşımı (8s). Apps Script URL\'nizi ve dağıtım ayarlarını kontrol edin.'));
      }
    }, 8000);

    document.head.appendChild(script);
  });
}

