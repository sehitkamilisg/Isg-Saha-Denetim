<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=3.0, user-scalable=yes">
<title>ISG Denetim Sistemi – Şehitkamil İlçe MEM</title>

<style>
/* ═══ GLOBAL ═══ */
:root {
  --bg:#0a0f1a; --sur:#111827; --sur2:#1a2336; --bdr:rgba(99,179,237,.12);
  --teal:#38bdf8; --red:#f87171; --amber:#fbbf24; --green:#34d399; --purple:#a78bfa;
  --txt:#f1f5f9; --mut:#64748b; --mut2:#94a3b8;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{font-family:Arial,sans-serif;background:var(--bg);color:var(--txt);min-height:100vh;}

/* ═══ DASHBOARD HEADER ═══ */
.d-header{
  background:linear-gradient(135deg,#0a0f1a,#111827 60%,#0c1629);
  border-bottom:1px solid var(--bdr);padding:20px 28px;
  display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;
}
.brand{display:flex;align-items:center;gap:12px;}
.brand-ico{width:46px;height:46px;border-radius:12px;background:linear-gradient(135deg,#38bdf8,#0ea5e9);display:flex;align-items:center;justify-content:center;font-size:22px;}
.brand h1{font-family:'Arial Black',Arial,sans-serif;font-size:15px;font-weight:800;line-height:1.3;}
.brand p{color:var(--mut2);font-size:11px;margin-top:2px;}
.live-badge{display:flex;align-items:center;gap:6px;background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.25);color:var(--green);padding:5px 12px;border-radius:20px;font-size:12px;font-weight:600;}
.live-dot{width:7px;height:7px;border-radius:50%;background:var(--green);animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.btn-new{display:flex;align-items:center;gap:8px;background:linear-gradient(135deg,#38bdf8,#0ea5e9);color:#0a0f1a;font-weight:700;font-size:14px;padding:10px 20px;border-radius:12px;border:none;cursor:pointer;font-family:Arial,sans-serif;box-shadow:0 4px 16px rgba(56,189,248,.3);transition:all .2s;}
.btn-new:hover{transform:translateY(-1px);box-shadow:0 6px 22px rgba(56,189,248,.45);}
.btn-pdf{display:flex;align-items:center;gap:7px;background:linear-gradient(135deg,#7c3aed,#6d28d9);color:#fff;font-weight:700;font-size:13px;padding:9px 18px;border-radius:12px;border:none;cursor:pointer;font-family:Arial,sans-serif;box-shadow:0 4px 14px rgba(124,58,237,.35);transition:all .2s;}
.btn-pdf:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(124,58,237,.5);}
.btn-pdf:disabled{opacity:.6;cursor:not-allowed;transform:none;}
.pdf-spin{display:none;width:13px;height:13px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin 1s linear infinite;}
.pdf-spin.show{display:inline-block;}

/* ═══ APPS SCRIPT AYAR SATIRI ═══ */
.config-bar{
  background:rgba(251,191,36,.07);border-bottom:1px solid rgba(251,191,36,.2);
  padding:8px 28px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;
}
.config-bar.connected{background:rgba(52,211,153,.07);border-color:rgba(52,211,153,.2);}
.cfg-lbl{font-size:11px;font-weight:700;color:var(--amber);white-space:nowrap;}
.config-bar.connected .cfg-lbl{color:var(--green);}
.cfg-input{
  flex:1;min-width:260px;padding:5px 11px;border-radius:8px;
  border:1px solid rgba(251,191,36,.3);background:rgba(0,0,0,.3);
  color:var(--txt);font-size:11px;font-family:Arial,sans-serif;outline:none;
}
.config-bar.connected .cfg-input{border-color:rgba(52,211,153,.3);}
.cfg-input:focus{border-color:var(--amber);}
.config-bar.connected .cfg-input:focus{border-color:var(--green);}
.cfg-btn{padding:5px 13px;border-radius:8px;border:none;font-size:11px;font-weight:700;cursor:pointer;font-family:Arial,sans-serif;transition:all .2s;}
.cfg-save{background:var(--amber);color:#0a0f1a;}
.cfg-sync{background:var(--green);color:#0a0f1a;display:flex;align-items:center;gap:5px;}
.cfg-status{font-size:11px;font-weight:600;padding:3px 9px;border-radius:6px;}
.cfg-status.ok{background:rgba(52,211,153,.15);color:var(--green);}
.cfg-status.warn{background:rgba(251,191,36,.15);color:var(--amber);}
.cfg-status.err{background:rgba(248,113,113,.15);color:var(--red);}

/* ═══ FILTERS ═══ */
.filters{background:var(--sur);border-bottom:1px solid var(--bdr);padding:10px 28px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.fl{color:var(--mut);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.8px;}
.fb{padding:5px 13px;border-radius:20px;border:1px solid var(--bdr);background:transparent;color:var(--mut2);font-size:12px;cursor:pointer;transition:all .2s;font-family:Arial,sans-serif;}
.fb.active,.fb:hover{background:rgba(56,189,248,.12);border-color:rgba(56,189,248,.4);color:var(--teal);}

/* ═══ DASHBOARD MAIN ═══ */
.d-main{padding:24px 28px;max-width:1400px;margin:0 auto;}
.kpi-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:20px;}
@media(max-width:900px){.kpi-grid{grid-template-columns:repeat(2,1fr);}}
.kpi{background:var(--sur);border:1px solid var(--bdr);border-radius:14px;padding:18px 16px;position:relative;overflow:hidden;transition:transform .2s;animation:fadeUp .5s ease both;}
.kpi:hover{transform:translateY(-2px);}
.kpi::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;border-radius:0 0 14px 14px;}
.kpi.k1::after{background:var(--teal);}.kpi.k2::after{background:var(--red);}.kpi.k3::after{background:var(--amber);}.kpi.k4::after{background:var(--green);}.kpi.k5::after{background:var(--purple);}
.kpi-ico{font-size:20px;margin-bottom:8px;}
.kpi-lbl{font-size:10px;color:var(--mut);text-transform:uppercase;letter-spacing:.9px;margin-bottom:5px;}
.kpi-val{font-family:'Arial Black',Arial,sans-serif;font-weight:800;font-size:30px;line-height:1;}
.kpi.k1 .kpi-val{color:var(--teal);}.kpi.k2 .kpi-val{color:var(--red);}.kpi.k3 .kpi-val{color:var(--amber);}.kpi.k4 .kpi-val{color:var(--green);}.kpi.k5 .kpi-val{color:var(--purple);}
.kpi-sub{font-size:10px;color:var(--mut);margin-top:4px;}
/* ── EBYS TAKİP PANELİ ── */
.ebys-panel-header:hover .ctitle{color:var(--teal);}
.ebys-detay-wrap{
  max-height:0;overflow:hidden;
  transition:max-height .35s cubic-bezier(.4,0,.2,1), opacity .3s ease;
  opacity:0;
}
.ebys-detay-wrap.open{max-height:2000px;opacity:1;}
.ebysPanelToggleIco.open{transform:rotate(180deg);}
.ebys-kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;}
@media(max-width:700px){.ebys-kpi-row{grid-template-columns:repeat(2,1fr);}}

/* ── PERSONEL PROFİLİ PANELİ ── */
.pp-header{cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:8px;}
.pp-header:hover .ctitle{color:var(--teal);}
.pp-detay{max-height:0;overflow:hidden;transition:max-height .35s cubic-bezier(.4,0,.2,1),opacity .3s;opacity:0;}
.pp-detay.open{max-height:3000px;opacity:1;}
.pp-ozet-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:8px;margin-top:14px;}
@media(max-width:900px){.pp-ozet-grid{grid-template-columns:repeat(3,1fr);}}
@media(max-width:500px){.pp-ozet-grid{grid-template-columns:repeat(2,1fr);}}
.pp-kart{background:var(--card2);border:1px solid rgba(255,255,255,.07);border-radius:10px;padding:12px 10px;text-align:center;}
.pp-kart-ico{font-size:20px;margin-bottom:4px;}
.pp-kart-val{font-size:22px;font-weight:700;color:var(--fg1);line-height:1.1;}
.pp-kart-lbl{font-size:10px;color:var(--mut2);margin-top:3px;text-transform:uppercase;letter-spacing:.5px;}
.pp-kart-sub{font-size:10px;color:var(--mut2);margin-top:2px;}
.pp-bar-wrap{margin-top:16px;}
.pp-bar-row{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
.pp-bar-lbl{font-size:11px;color:var(--mut1);width:140px;flex-shrink:0;text-align:right;}
.pp-bar-outer{flex:1;background:rgba(255,255,255,.07);border-radius:4px;height:18px;overflow:hidden;}
.pp-bar-inner{height:100%;border-radius:4px;transition:width .5s ease;display:flex;align-items:center;padding-left:6px;}
.pp-bar-num{font-size:10px;font-weight:700;color:#fff;white-space:nowrap;}
.pp-okul-tablo{margin-top:16px;width:100%;border-collapse:collapse;font-size:11px;}
.pp-okul-tablo th{background:var(--navy);color:#fff;padding:6px 8px;text-align:left;font-weight:600;}
.pp-okul-tablo td{padding:5px 8px;border-bottom:1px solid rgba(255,255,255,.05);}
.pp-okul-tablo tr:hover td{background:rgba(255,255,255,.04);}
.pp-okul-tablo .pp-tot{font-weight:700;color:var(--teal);}
.pp-toggle-ico{font-size:13px;color:var(--mut2);transition:transform .25s;display:inline-block;}
.ebys-kpi{border-radius:10px;padding:14px 12px;cursor:pointer;transition:transform .15s,box-shadow .15s;border:1px solid rgba(255,255,255,.07);text-align:center;}
.ebys-kpi:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgba(0,0,0,.3);}
.ek-red   {background:rgba(220,38,38,.15);border-color:rgba(220,38,38,.3);}
.ek-amber {background:rgba(245,158,11,.15);border-color:rgba(245,158,11,.3);}
.ek-blue  {background:rgba(59,130,246,.15);border-color:rgba(59,130,246,.3);}
.ek-green {background:rgba(16,185,129,.15);border-color:rgba(16,185,129,.3);}
.ekpi-ico{font-size:18px;margin-bottom:4px;}
.ekpi-val{font-family:'Arial Black',Arial,sans-serif;font-weight:800;font-size:26px;line-height:1;}
.ek-red   .ekpi-val{color:#f87171;}
.ek-amber .ekpi-val{color:#fbbf24;}
.ek-blue  .ekpi-val{color:#60a5fa;}
.ek-green .ekpi-val{color:#34d399;}
.ekpi-lbl{font-size:10px;color:var(--mut2);margin-top:4px;text-transform:uppercase;letter-spacing:.7px;}
/* EBYS liste satırları */
.ebys-satir{display:grid;grid-template-columns:1fr auto auto auto;gap:8px;align-items:center;padding:8px 10px;border-radius:7px;margin-bottom:4px;font-size:12px;border:1px solid rgba(255,255,255,.05);}
.ebys-satir:hover{background:rgba(255,255,255,.04);}
.ebys-okul{font-weight:600;color:var(--fg);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.ebys-tarih{font-size:11px;color:var(--mut2);white-space:nowrap;}
.ebys-badge{display:inline-block;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:700;white-space:nowrap;}
.eb-red   {background:rgba(220,38,38,.2);color:#f87171;}
.eb-amber {background:rgba(245,158,11,.2);color:#fbbf24;}
.eb-blue  {background:rgba(59,130,246,.2);color:#60a5fa;}
.eb-green {background:rgba(16,185,129,.2);color:#34d399;}
.eb-gray  {background:rgba(100,116,139,.2);color:#94a3b8;}
.ebys-aktif{box-shadow:0 0 0 2px var(--teal) inset;}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

.chart-row{display:grid;gap:16px;margin-bottom:16px;}
.cr2{grid-template-columns:1fr 1fr;}.cr3{grid-template-columns:2fr 1fr;}
@media(max-width:800px){.cr2,.cr3{grid-template-columns:1fr;}}
.card{background:var(--sur);border:1px solid var(--bdr);border-radius:14px;padding:20px;animation:fadeUp .5s ease .2s both;}
.ctitle{font-family:'Arial Black',Arial,sans-serif;font-weight:700;font-size:13px;margin-bottom:16px;display:flex;align-items:center;gap:7px;}

/* ═══ KATEGORİ BAR — YENİ AKORDİYON YAPISI ═══ */
.bar-list{display:flex;flex-direction:column;gap:6px;}
.kat-accordion{border-radius:8px;overflow:hidden;border:1px solid rgba(99,179,237,.1);}
.kat-bar-row{
  display:flex;align-items:center;gap:8px;padding:8px 10px;
  cursor:pointer;background:rgba(255,255,255,.03);
  transition:background .15s;user-select:none;
}
.kat-bar-row:hover{background:rgba(255,255,255,.06);}
.kat-bar-lbl{font-size:11px;color:var(--mut2);width:160px;flex-shrink:0;font-weight:600;}
.bar-trk{flex:1;height:20px;background:rgba(255,255,255,.05);border-radius:5px;overflow:hidden;}
.bar-fill{height:100%;border-radius:5px;display:flex;align-items:center;justify-content:flex-end;padding-right:6px;font-size:10px;font-weight:700;color:#fff;min-width:24px;transition:width 1.4s cubic-bezier(.4,0,.2,1);}
.kat-toggle{font-size:10px;color:var(--mut);transition:transform .2s;flex-shrink:0;width:14px;text-align:center;}
.kat-toggle.open{transform:rotate(180deg);}

/* Açılır madde listesi */
.kat-detail{
  display:none;background:rgba(0,0,0,.25);
  border-top:1px solid rgba(99,179,237,.08);
}
.kat-detail.open{display:block;}
.kat-detail-header{
  display:grid;grid-template-columns:1fr 70px 70px 70px 70px;
  gap:4px;padding:6px 10px;
  background:rgba(255,255,255,.05);
  font-size:10px;font-weight:700;color:var(--mut);
  text-transform:uppercase;letter-spacing:.5px;
}
.kat-madde-row{
  display:grid;grid-template-columns:1fr 70px 70px 70px 70px;
  gap:4px;padding:7px 10px;border-top:1px solid rgba(255,255,255,.03);
  align-items:center;transition:background .1s;
}
.kat-madde-row:hover{background:rgba(255,255,255,.02);}
.kat-madde-no{font-size:10px;font-weight:700;color:var(--teal);margin-right:4px;flex-shrink:0;}
.kat-madde-ad{font-size:11px;color:var(--mut2);line-height:1.4;}
.kat-madde-cell{font-size:11px;font-weight:700;text-align:center;}
.kat-cell-evet{color:var(--green);}
.kat-cell-hayir{color:var(--red);}
.kat-cell-eksik{color:var(--amber);}
.kat-cell-ger{color:var(--mut);}
.kat-detail-footer{
  display:grid;grid-template-columns:1fr 70px 70px 70px 70px;
  gap:4px;padding:7px 10px;
  background:rgba(255,255,255,.06);
  border-top:1px solid rgba(99,179,237,.15);
  font-size:11px;font-weight:700;
}
.kat-footer-lbl{color:var(--teal);}
.kat-footer-cell{text-align:center;}

/* ═══ RİSK SIRALAMASI — YENİ % YAPISI ═══ */
.risk-row{display:flex;align-items:center;gap:8px;padding:9px 0;border-bottom:1px solid rgba(255,255,255,.04);}
.risk-row:last-child{border:none;}
.risk-okul{flex:1;font-size:12px;font-weight:500;}
.risk-okul span{display:block;font-size:10px;color:var(--mut);font-weight:400;margin-top:1px;}
.risk-bar{width:80px;height:6px;background:rgba(255,255,255,.06);border-radius:3px;overflow:hidden;}
.risk-bar-f{height:100%;border-radius:3px;}
.risk-score{font-family:'Arial Black',Arial,sans-serif;font-weight:700;font-size:13px;width:52px;text-align:right;}

.dtable{width:100%;border-collapse:collapse;font-size:12px;}
.dtable th{color:var(--mut);font-size:10px;text-transform:uppercase;letter-spacing:.8px;padding:6px 10px;border-bottom:1px solid var(--bdr);text-align:left;font-weight:600;}
.dtable td{padding:9px 10px;border-bottom:1px solid rgba(255,255,255,.04);color:var(--mut2);vertical-align:middle;}
.dtable td:first-child{color:var(--txt);font-weight:500;}
.dtable tr:last-child td{border:none;}
.dtable tr:hover td{background:rgba(255,255,255,.02);}
.badge{display:inline-block;padding:2px 8px;border-radius:8px;font-size:10px;font-weight:700;}
.b-bek{background:rgba(251,191,36,.12);color:var(--amber);}
.b-teh{background:rgba(248,113,113,.12);color:var(--red);border:1px solid rgba(248,113,113,.2);}
.b-az{background:rgba(52,211,153,.12);color:var(--green);border:1px solid rgba(52,211,153,.2);}
.b-kap{background:rgba(52,211,153,.2);color:var(--green);border:1px solid rgba(52,211,153,.4);}
.mini-stats{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px;}
.ms{background:var(--sur2);border-radius:8px;padding:11px 12px;border:1px solid var(--bdr);}
.ms-lbl{font-size:10px;color:var(--mut);text-transform:uppercase;letter-spacing:.8px;margin-bottom:4px;}
.ms-val{font-family:'Arial Black',Arial,sans-serif;font-weight:800;font-size:20px;}
.red{color:var(--red);}.amber{color:var(--amber);}.green{color:var(--green);}.teal{color:var(--teal);}
.tur-row{display:flex;align-items:center;gap:7px;margin-bottom:7px;}
.tur-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.tur-nm{flex:1;font-size:12px;color:var(--mut2);}
.tur-cnt{font-family:'Arial Black',Arial,sans-serif;font-weight:700;font-size:13px;}
.tur-bar{width:60px;height:4px;background:rgba(255,255,255,.05);border-radius:2px;overflow:hidden;}
.tur-bar-f{height:100%;border-radius:2px;}
.d-footer{text-align:center;padding:16px;color:var(--mut);font-size:11px;border-top:1px solid var(--bdr);margin-top:6px;}
.risk-search{width:100%;padding:5px 11px;border-radius:8px;border:1px solid var(--bdr);background:rgba(0,0,0,.3);color:var(--txt);font-size:12px;font-family:Arial,sans-serif;outline:none;margin-bottom:10px;}
.risk-search:focus{border-color:var(--teal);}
.risk-pg-btn{padding:3px 9px;border-radius:6px;border:1px solid var(--bdr);background:transparent;color:var(--mut2);font-size:11px;font-weight:700;cursor:pointer;font-family:Arial,sans-serif;transition:all .15s;}
.risk-pg-btn:hover{background:rgba(56,189,248,.1);color:var(--teal);}
.risk-pg-btn.aktif{background:rgba(56,189,248,.15);border-color:rgba(56,189,248,.4);color:var(--teal);}
/* ═══ YENİ ÖZET ANALİZ KARTI ═══ */
.plan-input-row{display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;}
.plan-inp-box{flex:1;min-width:100px;}
.plan-inp-lbl{font-size:10px;color:var(--mut);text-transform:uppercase;letter-spacing:.7px;margin-bottom:4px;}
.plan-inp{width:100%;padding:6px 10px;border-radius:8px;border:1px solid var(--bdr);background:rgba(0,0,0,.25);color:var(--txt);font-size:13px;font-weight:700;font-family:Arial,sans-serif;outline:none;text-align:center;}
.plan-inp:focus{border-color:var(--teal);}
.plan-save-btn{align-self:flex-end;padding:6px 14px;border-radius:8px;border:none;background:var(--teal);color:#0a0f1a;font-size:11px;font-weight:700;cursor:pointer;font-family:Arial,sans-serif;white-space:nowrap;}
.plan-save-btn:hover{opacity:.85;}

.plan-progress-wrap{margin-bottom:14px;}
.plan-prog-top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:5px;}
.plan-prog-lbl{font-size:11px;color:var(--mut2);font-weight:600;}
.plan-prog-pct{font-family:'Arial Black',Arial,sans-serif;font-size:18px;font-weight:800;}
.plan-prog-bar{height:10px;background:rgba(255,255,255,.07);border-radius:5px;overflow:hidden;margin-bottom:6px;}
.plan-prog-fill{height:100%;border-radius:5px;background:linear-gradient(90deg,#38bdf8,#34d399);transition:width 1s cubic-bezier(.4,0,.2,1);}
.plan-prog-alt{font-size:10px;color:var(--mut);display:flex;justify-content:space-between;}

.ay-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:3px;margin-bottom:14px;}
.ay-col{display:flex;flex-direction:column;align-items:center;gap:2px;}
.ay-bar-wrap{width:100%;height:40px;background:rgba(255,255,255,.05);border-radius:3px;overflow:hidden;display:flex;align-items:flex-end;}
.ay-bar-gercek{width:100%;border-radius:3px 3px 0 0;transition:height .8s ease;min-height:0;}
.ay-bar-hedef{width:100%;height:2px;background:rgba(251,191,36,.5);flex-shrink:0;}
.ay-lbl{font-size:9px;color:var(--mut);text-align:center;}
.ay-sayi{font-size:9px;font-weight:700;color:var(--mut2);}

.kapsam-row{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
.kapsam-donut{position:relative;width:52px;height:52px;flex-shrink:0;}
.kapsam-donut svg{transform:rotate(-90deg);}
.kapsam-donut-pct{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;font-family:'Arial Black',Arial,sans-serif;}
.kapsam-detay{flex:1;}
