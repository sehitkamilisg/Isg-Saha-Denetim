  const riskler      = v.map(d => ({ ...d, pct: parseFloat(((((d.hayir||0)+(d.eksik||0))/138)*100).toFixed(1)) }));
  const ortRisk      = (riskler.reduce((s,d) => s+d.pct, 0) / top).toFixed(1);
  const siraliBuyuk  = [...riskler].sort((a,b) => b.pct-a.pct);
