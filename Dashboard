globalThis.ugMaddeleriYukle = async function(uid, okulEnc, tarihEnc) {
  if (!APPS_SCRIPT_URL) { toast('Apps Script URL girilmedi', 't-warn'); return; }
  var btn = document.getElementById(uid + '_ugYukle');
  if (btn) { btn.disabled = true; btn.textContent = 'Yukleniyor...'; }

  try {
    var data = null;

    // Yontem 1: doPost uzerinden fetch
    try {
      var resp = await fetch(APPS_SCRIPT_URL, {
        method: 'POST', redirect: 'follow',
        headers: {'Content-Type': 'text/plain;charset=utf-8'},
        body: JSON.stringify({
          action: 'uygunsuzlukGidermeGetir',
          okulAdi: decodeURIComponent(okulEnc),
          denetimTarihi: decodeURIComponent(tarihEnc)
        })
      });
      var rawText = await resp.text();
      console.log('ugMaddeleriYukle rawText (ilk 200):', rawText.substring(0, 200));
      try { data = JSON.parse(rawText); } catch(pe) {
        console.log('JSON parse basarisiz, JSONP deneniyor...');
        data = null;
      }
    } catch(fetchErr) {
      console.log('Fetch hatasi:', fetchErr.message);
      data = null;
    }

    // Yontem 2: JSONP fallback (GET ile)
    if (!data || !data.status) {
      try {
        console.log('JSONP fallback deneniyor...');
        data = await new Promise(function(resolve, reject) {
          var cbName = '_ugCb_' + Date.now();
          var url = APPS_SCRIPT_URL +
            (APPS_SCRIPT_URL.indexOf('?') >= 0 ? '&' : '?') +
            'action=uygunsuzlukGidermeGetir' +
            '&okulAdi=' + okulEnc +
            '&denetimTarihi=' + tarihEnc +
            '&callback=' + cbName +
            '&t=' + Date.now();
          window[cbName] = function(d) { resolve(d); delete window[cbName]; };
          var s = document.createElement('script');
          s.src = url;
          s.onerror = function() { reject(new Error('JSONP hata')); delete window[cbName]; };
          document.head.appendChild(s);
          setTimeout(function() { if (window[cbName]) { reject(new Error('Zaman asimi')); delete window[cbName]; } }, 15000);
        });
      } catch(jpErr) {
        console.log('JSONP hatasi:', jpErr.message);
      }
    }

    if (!data || !data.status) {
      toast('Backend yanit alinamadi - konsolu kontrol edin (F12)', 't-err');
      if (btn) { btn.disabled = false; btn.textContent = 'Tekrar dene'; }
      return;
    }

    console.log('ugMaddeleriYukle data:', data);
    if (data.status !== 'OK') { toast('Backend hata: ' + (data.mesaj || ''), 't-err'); if (btn) { btn.disabled = false; btn.textContent = 'Tekrar dene'; } return; }

    if (data.maddeler && data.maddeler.length > 0) {
      _ugDurum[uid] = {};
      var liste = document.getElementById(uid + '_ugListe');

      // Toplu secim butonlari
      var html = '<div class="ug-tumunu-sec">' +
        '<button class="ug-tumunu-btn" onclick="ugTumunuSec(\'' + uid + '\',\'Giderildi\')">Tumunu Giderildi</button>' +
        '<button class="ug-tumunu-btn" onclick="ugTumunuSec(\'' + uid + '\',\'Giderilmedi\')">Tumunu Giderilmedi</button>' +
        '<span style="font-size:10px;color:var(--mut)">' + data.maddeler.length + ' madde</span>' +
      '</div>';

      data.maddeler.forEach(function(m) {
        _ugDurum[uid][m.no] = ''; // bos = secilmedi
        html += '<div class="ug-madde" id="' + uid + '_ugM' + m.no + '">' +
          '<div><span class="ug-madde-no">' + m.no + '.</span> <span class="ug-madde-ad">' + m.ad + '</span>' +
            ' <span style="font-size:9px;color:' + (m.cevap === 'Hay\u0131r/Yok' ? 'var(--red)' : 'var(--amber)') + '">[' + m.cevap + ']</span></div>' +
          '<div class="ug-madde-durum">' +
            '<button class="ug-btn" onclick="ugSecim(\'' + uid + '\',' + m.no + ',\'Giderildi\',this)">Giderildi</button>' +
            '<button class="ug-btn" onclick="ugSecim(\'' + uid + '\',' + m.no + ',\'Kismen\',this)">Kismen</button>' +
            '<button class="ug-btn" onclick="ugSecim(\'' + uid + '\',' + m.no + ',\'Giderilmedi\',this)">Giderilmedi</button>' +
          '</div>' +
        '</div>';
      });

      // Kaydet butonu
      html += '<div style="display:flex;gap:8px;margin-top:8px;align-items:center">' +
        '<button class="ug-kaydet-btn" id="' + uid + '_ugKaydet" ' +
          'onclick="ugKaydet(\'' + uid + '\',\'' + okulEnc + '\',\'' + tarihEnc + '\')">Giderme Kaydet</button>' +
        '<span id="' + uid + '_ugDurum" style="font-size:11px;color:var(--mut2)"></span>' +
      '</div>';

      liste.innerHTML = html;
      if (btn) { btn.textContent = 'Yukle (yuklu)'; btn.disabled = false; }
      toast(data.maddeler.length + ' uygunsuz madde yuklendi', 't-ok');

    } else if (!data.maddeler || data.maddeler.length === 0) {
      toast('Madde bulunamadi. Toplam:' + (data.toplamUygunsuz || 0) + ' Mesaj:' + (data.mesaj || '-'), 't-warn');
      if (btn) { btn.textContent = 'Bulunamadi (' + (data.toplamUygunsuz || 0) + ')'; btn.disabled = false; }
    } else {
      toast('Hata: ' + (data.mesaj || ''), 't-err');
      if (btn) { btn.textContent = 'Tekrar dene'; btn.disabled = false; }
    }
  } catch(e) {
    toast('Baglanti hatasi: ' + e.message, 't-err');
    if (btn) { btn.textContent = 'Tekrar dene'; btn.disabled = false; }
  }
};

globalThis.ugSecim = function(uid, no, durum, el) {
  if (!_ugDurum[uid]) return;
  // Toggle: ayni butona tekrar basinca kaldir
  if (_ugDurum[uid][no] === durum) {
    _ugDurum[uid][no] = '';
    el.closest('.ug-madde-durum').querySelectorAll('.ug-btn').forEach(function(b){ b.className = 'ug-btn'; });
  } else {
    _ugDurum[uid][no] = durum;
    el.closest('.ug-madde-durum').querySelectorAll('.ug-btn').forEach(function(b){ b.className = 'ug-btn'; });
    if (durum === 'Giderildi') el.classList.add('ug-giderildi');
    else if (durum === 'Kismen') el.classList.add('ug-kismen');
    else el.classList.add('ug-giderilmedi');
  }
  ugOzetGuncelle(uid);
};

globalThis.ugTumunuSec = function(uid, durum) {
  if (!_ugDurum[uid]) return;
  Object.keys(_ugDurum[uid]).forEach(function(no) {
    _ugDurum[uid][no] = durum;
    var row = document.getElementById(uid + '_ugM' + no);
    if (row) {
      row.querySelectorAll('.ug-btn').forEach(function(b) {
        b.className = 'ug-btn';
        if (durum === 'Giderildi' && b.textContent.indexOf('Giderildi') >= 0 && b.textContent.indexOf('Giderilmedi') < 0) b.classList.add('ug-giderildi');
        else if (durum === 'Kismen' && b.textContent === 'Kismen') b.classList.add('ug-kismen');
        else if (durum === 'Giderilmedi' && b.textContent === 'Giderilmedi') b.classList.add('ug-giderilmedi');
      });
    }
  });
  ugOzetGuncelle(uid);
};

globalThis.ugOzetGuncelle = function(uid) {
  if (!_ugDurum[uid]) return;
  var g = 0, k = 0, gm = 0, bos = 0;
  Object.values(_ugDurum[uid]).forEach(function(d) {
    if (d === 'Giderildi') g++;
    else if (d === 'Kismen') k++;
    else if (d === 'Giderilmedi') gm++;
    else bos++;
  });
  var toplam = g + k + gm + bos;
  var ozet = document.getElementById(uid + '_ugOzet');
  if (ozet) {
    ozet.className = 'ug-ozet show';
    ozet.innerHTML = 'Giderildi: <strong style="color:var(--green)">' + g + '</strong> | ' +
      'Kismen: <strong style="color:var(--amber)">' + k + '</strong> | ' +
      'Giderilmedi: <strong style="color:var(--red)">' + gm + '</strong>' +
      (bos > 0 ? ' | Secilmedi: ' + bos : '') +
      (g === toplam ? ' &mdash; <strong style="color:var(--green)">Tumu giderildi! Otomatik kapatilacak.</strong>' : '');
  }
};

globalThis.ugKaydet = async function(uid, okulEnc, tarihEnc) {
  if (!APPS_SCRIPT_URL || !_ugDurum[uid]) return;

  // En az bir secim yapilmis mi?
  var secimVar = Object.values(_ugDurum[uid]).some(function(d){ return d !== ''; });
  if (!secimVar) { toast('En az bir madde secin', 't-warn'); return; }

  var btn = document.getElementById(uid + '_ugKaydet');
  var durum = document.getElementById(uid + '_ugDurum');
  if (btn) btn.disabled = true;
  if (durum) durum.textContent = 'Kaydediliyor...';

  try {
    var resp = await fetch(APPS_SCRIPT_URL, {
      method: 'POST', redirect: 'follow',
      headers: {'Content-Type': 'text/plain;charset=utf-8'},
      body: JSON.stringify({
        action: 'uygunsuzlukGidermeKaydet',
        okulAdi: decodeURIComponent(okulEnc),
        denetimTarihi: decodeURIComponent(tarihEnc),
        giderilenMaddeler: _ugDurum[uid]
      })
    });
    var data = JSON.parse(await resp.text());

    if (data.status === 'OK') {
      // ── Bilgi mesajı ──
      var mesajParcalari = ['✅ ' + data.giderilen + ' madde giderildi'];
      if (data.kismen > 0) mesajParcalari.push(data.kismen + ' kısmen');
      if (data.kalan  > 0) mesajParcalari.push(data.kalan + ' hâlâ açık');
      else                  mesajParcalari.push('Tümü kapatıldı!');
      toast(mesajParcalari.join(' · '), 't-ok');
      if (durum) durum.innerHTML = '<span style="color:var(--green)">✅ Kaydedildi!</span>';

      // ── Dashboard verisini TAMAMEN güncelle ──
      var okul = decodeURIComponent(okulEnc);
      var dIdx = DENETIMLER.findIndex(function(d){ return d.okul === okul; });
      if (dIdx >= 0) {
        var dd = DENETIMLER[dIdx];

        // Backend'den gelen güncel hayır/eksik sayıları
        if (typeof data.yeniHayir === 'number') dd.hayir  = data.yeniHayir;
        if (typeof data.yeniEksik === 'number') dd.eksik  = data.yeniEksik;
        if (typeof data.yeniUyg   === 'number') { dd.uyg = data.yeniUyg; dd.toplam = data.yeniUyg; }
        dd.giderilen = data.giderilen;
        dd.kalan     = data.kalan;

        // Kategori kırılımları (yalnızca kalan açık maddeler)
        if (data.katSayac) dd.kat = data.katSayac;

        // Durum güncellemesi
        if (data.otomatikKapatildi) {
          dd.durum        = '✅ Kapatıldı';
          dd.cevap        = '✅ Cevaplandı';
          dd.kapatmaTarih = new Date().toLocaleDateString('tr-TR',{day:'2-digit',month:'2-digit',year:'numeric'});
        } else if (data.giderilen > 0) {
          dd.durum = '🟡 Kısmen Giderildi (' + data.giderilen + '/' + data.toplamUyg + ')';
        }

        // Giderilen maddeleri answers içinde Evet/Var yap
        // → Kategori barları ve "En sorunlu maddeler" doğru hesaplansın
        if (dd.answers && _ugDurum[uid]) {
          Object.keys(_ugDurum[uid]).forEach(function(no) {
            if (_ugDurum[uid][no] === 'Giderildi') {
              dd.answers[no]         = 'Evet/Var';
              dd.answers[parseInt(no)] = 'Evet/Var';
            }
          });
        }
      }

      // ── Tüm dashboard panellerini yeniden çiz ──
      renderEbysTakip(filtreliVeri());
      if (_ebysAktifFiltre) ebysListeFiltrele(_ebysAktifFiltre);
      renderDash();  // KPI, risk sıralaması, kategori barları, plan istatistikleri

    } else {
      toast('Hata: ' + (data.mesaj || ''), 't-err');
      if (durum) durum.textContent = 'Hata!';
    }
  } catch(e) {
    toast('Baglanti hatasi: ' + e.message, 't-err');
    if (durum) durum.textContent = 'Hata!';
  } finally {
    if (btn) btn.disabled = false;
  }
};

</script>



