const PP_KATEGORILER = [
  { id:'ogrenci',    lbl:'Öğrenci',        ico:'🎒', renk:'#0d9488' },
  { id:'cirak',      lbl:'Çırak/Stajyer',  ico:'🔧', renk:'#7c3aed' },
  { id:'ogretmen',   lbl:'Öğretmen',       ico:'📚', renk:'#2355a0' },
