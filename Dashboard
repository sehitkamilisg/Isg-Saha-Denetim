globalThis.raporYenileBaslat = async function(uid, okulEnc, tarihEnc) {
  if (!APPS_SCRIPT_URL) { toast('Apps Script URL girilmedi', 't-warn'); return; }

  var btn  = document.getElementById(uid + '_raporBtn');
  var spin = document.getElementById(uid + '_raporSpin');
  if (btn)  { btn.disabled = true; }
  if (spin) { spin.classList.add('show'); }

  var okul  = decodeURIComponent(okulEnc);
  var tarih = decodeURIComponent(tarihEnc);

  toast('🔄 Rapor yenileniyor: ' + okul + '…', '');

  try {
    var resp = await fetch(APPS_SCRIPT_URL, {
      method:   'POST',
      redirect: 'follow',
      headers:  { 'Content-Type': 'text/plain;charset=utf-8' },
      body:     JSON.stringify({
        action:        'raporYenile',
        okulAdi:       okul,
        denetimTarihi: tarih
      })
    });
    var data = JSON.parse(await resp.text());

    if (data.status === 'OK') {
      toast('✅ Rapor yenilendi: ' + okul, 't-ok');

      // DENETIMLER dizisinde raporUrl ve arsivler güncelle
      var dIdx = DENETIMLER.findIndex(function(d) { return d.okul === okul; });
      if (dIdx >= 0 && data.docUrl) {
        // Eski URL'yi arşiv listesine ekle
        if (DENETIMLER[dIdx].raporUrl) {
          if (!Array.isArray(DENETIMLER[dIdx].arsivler)) DENETIMLER[dIdx].arsivler = [];
          DENETIMLER[dIdx].arsivler.push({
            url:    DENETIMLER[dIdx].raporUrl,
            tarih:  new Date().toLocaleDateString('tr-TR', {day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}),
            baslik: 'Arşiv – ' + okul
          });
        }
        DENETIMLER[dIdx].raporUrl = data.docUrl;
      }

      // Butonu "Raporu Aç" linkine dönüştür
      if (btn && data.docUrl) {
        btn.disabled = false;
        btn.innerHTML = '<a href="' + data.docUrl + '" target="_blank" ' +
          'style="color:#a78bfa;text-decoration:none;font-size:11px;font-weight:700;">' +
          '📄 Yeni Raporu Aç</a>';
        btn.style.background = 'rgba(167,139,250,.2)';
        btn.style.borderColor = 'rgba(167,139,250,.5)';
      }

      // EBYS panelini güncelle (Doc linki değişti)
      renderEbysTakip(filtreliVeri());
      if (_ebysAktifFiltre) ebysListeFiltrele(_ebysAktifFiltre);

    } else {
      toast('❌ Rapor yenileme hatası: ' + (data.mesaj || 'Bilinmeyen hata'), 't-err');
      if (btn)  { btn.disabled = false; }
    }
  } catch(e) {
    toast('❌ Bağlantı hatası: ' + e.message, 't-err');
    if (btn) { btn.disabled = false; }
  } finally {
    if (spin) { spin.classList.remove('show'); }
  }
};

