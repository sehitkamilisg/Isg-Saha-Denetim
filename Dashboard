    katTop[k] = v.reduce((s,d) => s + ((d.kat&&d.kat[k]) ? parseInt(d.kat[k])||0 : 0), 0);
  });
  const katMax = Math.max(...Object.values(katTop), 1);

  // ── Canvas grafik: Risk bar ──
  function cizRiskBar() {
    const cnv = document.createElement('canvas');
    const sW = 820, rowH = 34, padTop = 36, padBot = 28, padL = 220, padR = 120;
    cnv.width  = sW;
