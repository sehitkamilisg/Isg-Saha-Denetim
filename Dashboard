    return;
  }
  const btn  = document.getElementById('btnPdfRapor');
  const spin = document.getElementById('pdfSpin');
  btn.disabled = true;
  spin.classList.add('show');
  btn.childNodes[btn.childNodes.length-1].textContent = ' Hazırlanıyor…';

  // Grafikleri canvas üzerinde çiz → dataURL al
  setTimeout(function() {
    try {
      const v = filtreliVeri();
      const raporHtml = _brifingHtmlOlustur(v);
      const win = window.open('', '_blank', 'width=900,height=700');
      win.document.write(raporHtml);
      win.document.close();
      // Tarayıcının render etmesini bekle, sonra yazdırma dialogu
      win.onload = function() {
        setTimeout(function() { win.print(); }, 400);
