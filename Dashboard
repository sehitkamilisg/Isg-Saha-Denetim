];

globalThis.renderPersonelPanel = function(v) {
  // Sadece personel verisi olan denetimleri filtrele
  const pVeri = v.filter(d => d.personel);

  // Toplam hesapla
  const top = { ogrenci:0, cirak:0, ogretmen:0, memur:0, hizmetli:0, diger:0,
                ogretmenKS:0, memuKS:0, hizmetliKS:0, guvenlikKS:0, digerKS:0 };
  pVeri.forEach(d => {
    const p = d.personel;
    top.ogrenci   += (p.ogrenci   || 0);
    top.cirak     += (p.cirak     || 0);
    top.ogretmen  += (p.ogretmenK || 0) + (p.ogretmenKS || 0);
    top.memur     += (p.memuK     || 0) + (p.memuKS     || 0);
    top.hizmetli  += (p.hizmetliK || 0) + (p.hizmetliKS || 0);
    top.diger     += (p.guvenlikK || 0) + (p.guvenlikKS || 0) + (p.digerK || 0) + (p.digerKS || 0);
  });
  const genelToplam = Object.values(top).reduce((a,b)=>a+b,0);
  const personelToplam = top.ogretmen + top.memur + top.hizmetli + top.diger;

  // KPI kartlarını güncelle
  const guncelleKart = (id, val, subTxt) => {
    const el = document.getElementById('pp' + id.charAt(0).toUpperCase() + id.slice(1));
    const subEl = document.getElementById('pp' + id.charAt(0).toUpperCase() + id.slice(1) + 'Sub');
    if (el) el.textContent = val.toLocaleString('tr-TR');
    if (subEl) subEl.textContent = subTxt || '';
  };
  guncelleKart('Ogrenci',  top.ogrenci,  top.ogrenci  ? '%' + Math.round(top.ogrenci/(genelToplam||1)*100) + ' oran' : '—');
  guncelleKart('Cirak',    top.cirak,    top.cirak    ? '%' + Math.round(top.cirak/(genelToplam||1)*100) + ' oran' : '—');
  guncelleKart('Ogretmen', top.ogretmen, top.ogretmen ? '%' + Math.round(top.ogretmen/(genelToplam||1)*100) + ' oran' : '—');
  guncelleKart('Memur',    top.memur,    top.memur    ? '%' + Math.round(top.memur/(genelToplam||1)*100) + ' oran' : '—');
  guncelleKart('Hizmetli', top.hizmetli, top.hizmetli ? '%' + Math.round(top.hizmetli/(genelToplam||1)*100) + ' oran' : '—');
  guncelleKart('Diger',    top.diger,    top.diger    ? '%' + Math.round(top.diger/(genelToplam||1)*100) + ' oran' : '—');

  // Üst bilgi
  const toplamBilgiEl = document.getElementById('ppToplamBilgi');
  if (toplamBilgiEl) toplamBilgiEl.textContent = pVeri.length + ' denetimden · Toplam: ' + genelToplam.toLocaleString('tr-TR') + ' kişi';

  const ozetEl = document.getElementById('ppOzetBilgi');
  if (ozetEl) {
    const max = PP_KATEGORILER.reduce((a,b) => top[b.id] > top[a.id] ? b : a);
    ozetEl.textContent = pVeri.length ? 'En kalabalık: ' + max.lbl + ' (' + top[max.id].toLocaleString('tr-TR') + ')' : '';
  }

  // Oran barları
  const barEl = document.getElementById('ppBarlar');
  if (barEl) {
    const maxVal = Math.max(...PP_KATEGORILER.map(k => top[k.id]), 1);
    barEl.innerHTML = '<div style="font-size:11px;font-weight:600;color:var(--mut2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;">Kategori Dağılımı</div>' +
      PP_KATEGORILER.map(k => {
        const val = top[k.id];
        const pct = Math.round(val / maxVal * 100);
        return '<div class="pp-bar-row">' +
          '<div class="pp-bar-lbl">' + k.ico + ' ' + k.lbl + '</div>' +
          '<div class="pp-bar-outer"><div class="pp-bar-inner" style="width:' + pct + '%;background:' + k.renk + '">' +
          '<span class="pp-bar-num">' + (val > 0 ? val.toLocaleString('tr-TR') : '') + '</span></div></div>' +
          '<div style="font-size:10px;color:var(--mut2);width:36px;text-align:right">' +
          (genelToplam > 0 ? '%' + Math.round(val/genelToplam*100) : '—') + '</div>' +
          '</div>';
      }).join('');
  }

  // Okul bazında tablo
  const tbody = document.getElementById('ppOkulTbody');
  if (tbody) {
    if (pVeri.length === 0) {
      tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;color:var(--mut2);padding:16px;">Henüz personel verisi girilmemiş.<br><small>Yeni denetim formundan personel bilgilerini doldurun.</small></td></tr>';
    } else {
      tbody.innerHTML = pVeri.map(d => {
        const p = d.personel;
        const ogr = (p.ogretmenK||0)+(p.ogretmenKS||0);
        const mem = (p.memuK||0)+(p.memuKS||0);
        const hiz = (p.hizmetliK||0)+(p.hizmetliKS||0);
        const dig = (p.guvenlikK||0)+(p.guvenlikKS||0)+(p.digerK||0)+(p.digerKS||0);
        const tot = (p.ogrenci||0)+(p.cirak||0)+ogr+mem+hiz+dig;
        return '<tr>' +
          '<td>' + d.okul + '<br><small style="color:var(--mut2)">' + (d.tur||'') + '</small></td>' +
          '<td style="color:var(--mut2)">' + (d.tarih||'') + '</td>' +
          '<td style="color:#0d9488;font-weight:600">' + (p.ogrenci||0) + '</td>' +
          '<td style="color:#7c3aed;font-weight:600">' + (p.cirak||0) + '</td>' +
          '<td>' + ogr + (p.ogretmenKS > 0 ? '<small style="color:var(--mut2)"> (+'+p.ogretmenKS+'ks)</small>' : '') + '</td>' +
          '<td>' + mem + (p.memuKS > 0 ? '<small style="color:var(--mut2)"> (+'+p.memuKS+'ks)</small>' : '') + '</td>' +
          '<td>' + hiz + '</td>' +
          '<td>' + dig + '</td>' +
          '<td class="pp-tot">' + tot.toLocaleString('tr-TR') + '</td>' +
          '</tr>';
      }).join('');
    }
  }
};

