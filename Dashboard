globalThis.renderEbysTakip = function(v) {
  const bugun = new Date(); bugun.setHours(0,0,0,0);

  // Her denetim için EBYS durumunu sınıflandır
  _ebysVeri = v.map(d => {
    const durumStr = (d.durum || '').toLowerCase();
    const ebysStr  = (d.ebys  || '').toLowerCase();
    const cevapStr = (d.cevap || '').toLowerCase();

    let sinif, badge, badgeCls;

    if (durumStr.includes('kapatıldı') || durumStr.includes('kapati')) {
      sinif = 'kapatildi'; badge = '✅ Kapatıldı'; badgeCls = 'eb-green';
    } else if (ebysStr.includes('bekliyor') || ebysStr.includes('gönderilmedi') || !d.ebysTarih) {
      sinif = 'yazigonderilmedi'; badge = '✉️ Yazı Yok'; badgeCls = 'eb-red';
    } else {
      // Yazı gönderilmiş — cevap süresini kontrol et
      // Önce cevap durumunu kontrol et: cevap geldiyse "cevap bekleniyor" sayma
      const cevapGeldi = cevapStr.includes('cevap') || cevapStr.includes('tamaml') || cevapStr.includes('yerine');

      let sureDoldu = false;

      // cevapTarih varsa onu kullan; yoksa ebysTarih + 30 gün hesapla
      const _tarihParseTR = function(str) {
        if (!str) return null;
        str = String(str).trim();
        // GG.AA.YYYY
        if (/^\d{1,2}\.\d{1,2}\.\d{4}$/.test(str)) {
          const [g, ay, y] = str.split('.');
          return new Date(+y, +ay-1, +g);
        }
        // YYYY-MM-DD
        if (/^\d{4}-\d{2}-\d{2}$/.test(str)) {
          const [y, ay, g] = str.split('-');
          return new Date(+y, +ay-1, +g);
        }
        return null;
      };

      if (d.cevapTarih) {
        // cevapTarih = cevap için son tarih (GS'den geliyor)
        const cevapSon = _tarihParseTR(d.cevapTarih);
        if (cevapSon) sureDoldu = bugun > cevapSon;
      } else if (d.ebysTarih) {
        // cevapTarih yoksa: ebysTarih + 30 gün
        const ebysDt = _tarihParseTR(d.ebysTarih);
        if (ebysDt) {
          const hesaplananSon = new Date(ebysDt.getTime() + 30 * 86400000);
          sureDoldu = bugun > hesaplananSon;
        }
      }

      if (sureDoldu) {
        sinif = 'suredoldu'; badge = '🔴 Süre Doldu'; badgeCls = 'eb-amber';
      } else {
        sinif = 'cevapbekleniyor'; badge = '🔄 Cevap Bekleniyor'; badgeCls = 'eb-blue';
      }
    }
    return { ...d, _sinif: sinif, _badge: badge, _badgeCls: badgeCls };
  });

  // KPI sayıları
  const sayac = { yazigonderilmedi:0, suredoldu:0, cevapbekleniyor:0, kapatildi:0 };
  _ebysVeri.forEach(d => { if (sayac[d._sinif] !== undefined) sayac[d._sinif]++; });

  animNum('ekYaziGonderilmedi', sayac.yazigonderilmedi);
  animNum('ekSureDoldu',        sayac.suredoldu);
  animNum('ekCevapBekleniyor',  sayac.cevapbekleniyor);
  animNum('ekKapatildi',        sayac.kapatildi);

  document.getElementById('ebysToplamInfo').textContent = v.length + ' denetim';

  // Özet metni: en kritik durumu göster
  const ozet = sayac.suredoldu > 0
    ? '🔴 ' + sayac.suredoldu + ' süre aşımı'
    : sayac.yazigonderilmedi > 0
      ? '✉️ ' + sayac.yazigonderilmedi + ' yazı bekliyor'
      : sayac.cevapbekleniyor > 0
        ? '🔄 ' + sayac.cevapbekleniyor + ' cevap bekleniyor'
        : '✅ Tümü kapatıldı';
  const ozetEl = document.getElementById('ebysPanelOzet');
  if (ozetEl) ozetEl.textContent = ozet;

  // Aktif filtre varsa listeyi güncelle (panel açıksa)
  const detay = document.getElementById('ebysDetay');
  if (detay && detay.classList.contains('open')) {
    ebysListeFiltrele(_ebysAktifFiltre);
  }
};
