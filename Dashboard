.plan-form-iptal{padding:6px 12px;border-radius:7px;border:1px solid var(--bdr);background:transparent;color:var(--mut2);font-size:11px;cursor:pointer;font-family:Arial,sans-serif;}
.plan-liste-wrap{max-height:260px;overflow-y:auto;}
.plan-okul-row{display:flex;align-items:flex-start;gap:8px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.04);}
.plan-okul-row:last-child{border:none;}
.plan-okul-durum{width:20px;height:20px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:11px;margin-top:1px;}
