let riskTumVeri  = [];
let riskDrwSayfa = 0;
const RISK_SAYFA_BOYUT = 20;

// ─ Risk satırı HTML üretici (hem kart hem drawer için) ─
function _riskSatirHtml(d, sira) {
  const c  = d.pct >= 30 ? '#f87171' : d.pct >= 15 ? '#fbbf24' : '#34d399';
  const ad = d.okul.length > 34 ? d.okul.substring(0,34)+'…' : d.okul;
  return '<div class="risk-row">' +
    '<div style="width:22px;text-align:right;font-size:10px;color:var(--mut);flex-shrink:0">' + sira + '.</div>' +
    '<div class="risk-okul">' + ad + '<span>' + (d.tur||'–') + ' · ' + (d.tarih||'–') + '</span></div>' +
    '<div class="risk-bar"><div class="risk-bar-f" style="width:' + Math.min(100,d.pct) + '%;background:' + c + '"></div></div>' +
    '<div class="risk-score" style="color:' + c + '">%' + d.pct.toFixed(1) + '</div>' +
  '</div>';
}

globalThis.renderRiskList = function(v) {
  riskTumVeri = [...v].map(d => {
    const uyg = (d.hayir||0) + (d.eksik||0);
    const pct = parseFloat((uyg / 138 * 100).toFixed(1));
    return { ...d, uyg, pct };
  }).sort((a, b) => b.pct - a.pct);
  riskDrwSayfa = 0;

  // ─ İlk 5'i kartta göster ─
  const ilk5 = riskTumVeri.slice(0, 5);
  const listEl = document.getElementById('riskList');
