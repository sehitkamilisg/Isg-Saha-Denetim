globalThis.ebysGuncelleKaydet = async function(uid, okulEnc, tarihEnc) {
  if (!APPS_SCRIPT_URL) {
    toast('Önce Apps Script URL\'sini kaydedin', 't-warn');
    return;
  }

  const okul  = decodeURIComponent(okulEnc);
  const tarih = decodeURIComponent(tarihEnc);

  const yaziNo     = document.getElementById(uid + '_yaziNo')?.value.trim()    || '';
  const ebysTarih  = document.getElementById(uid + '_ebysTarih')?.value         || '';
  const ebysDurum  = document.getElementById(uid + '_ebysDurum')?.value         || '';
  const cevapTarih = document.getElementById(uid + '_cevapTarih')?.value        || '';
  const cevapDurum = document.getElementById(uid + '_cevapDurum')?.value        || '';
  const cevapNot   = document.getElementById(uid + '_cevapNot')?.value.trim()   || '';
  const kapatiCb   = document.getElementById(uid + '_kapatiCb')?.checked        || false;

  // HATA 4 DÜZELTMESİ: checkbox işaretliyse tarih alanından al,
  // boşsa şu anki tarihi güvenli şekilde al — DOM'a güvenme
  let kapatiTarih = document.getElementById(uid + '_kapatiTarih')?.value || '';
  if (kapatiCb && !kapatiTarih) {
    kapatiTarih = new Date().toISOString().split('T')[0];
  }

  const tarihGun = function(isoStr) {
    if (!isoStr) return '';
    const [y, m, d] = isoStr.split('-');
    if (!y || !m || !d) return '';
    return d + '.' + m + '.' + y;
  };

  const payload = {
    action:        'updateEbys',
    okulAdi:       okul,
    denetimTarihi: tarih,
    yazıNo:        yaziNo,
    ebysTarih:     tarihGun(ebysTarih),
    ebysDurum:     ebysDurum,
    cevapTarih:    tarihGun(cevapTarih),
    cevapDurum:    cevapDurum,
    cevapNot:      cevapNot,
    kapatmaTarih:  kapatiCb ? tarihGun(kapatiTarih) : '',
    genelDurum:    kapatiCb ? '✅ Kapatıldı' : ''
  };

  const btn  = document.getElementById(uid + '_kaydetBtn');
  const spin = document.getElementById(uid + '_spin');
  if (btn)  btn.disabled = true;
  if (spin) spin.classList.add('show');

  try {
    const resp = await fetch(APPS_SCRIPT_URL, {
      method:   'POST',
      redirect: 'follow',
      headers:  { 'Content-Type': 'text/plain;charset=utf-8' },
      body:     JSON.stringify(payload)
    });
    const text = await resp.text();
    let data = {};
    try { data = JSON.parse(text); } catch(e) {}

    if (data.status === 'OK') {

      // HATA 1 DÜZELTMESİ: DENETIMLER dizisini TAM olarak güncelle
      // (sadece ebys/cevap/durum değil, tüm alanlar)
      const dIdx = DENETIMLER.findIndex(d => d.okul === okul);
      if (dIdx >= 0) {
        if (yaziNo)     DENETIMLER[dIdx].yazıNo      = yaziNo;
        if (ebysTarih)  DENETIMLER[dIdx].ebysTarih   = tarihGun(ebysTarih);
        if (ebysDurum)  DENETIMLER[dIdx].ebys         = ebysDurum;
        if (cevapTarih) DENETIMLER[dIdx].cevapTarih   = tarihGun(cevapTarih);
        if (cevapDurum) DENETIMLER[dIdx].cevap         = cevapDurum;
        if (cevapNot)   DENETIMLER[dIdx].cevapNot      = cevapNot;
        if (kapatiCb) {
          DENETIMLER[dIdx].durum        = '✅ Kapatıldı';
          DENETIMLER[dIdx].kapatmaTarih = tarihGun(kapatiTarih);
        }
      }

      // HATA 2 DÜZELTMESİ: finally'den önce disable kaldır,
      // çünkü render sonrası DOM elemanı silinmiş olacak
      if (btn)  btn.disabled = false;
      if (spin) spin.classList.remove('show');

      toast('✅ EBYS güncellendi: ' + okul, 't-ok');

      // Formu kapat — render'dan önce, çünkü render tüm satırları yeniden çizer
      ebysFormToggle(uid);

      // DENETIMLER güncellendi, şimdi panel yeniden render edilsin
      // renderEbysTakip filtreliVeri()'den değil, doğrudan DENETIMLER'den üret
      renderEbysTakip(filtreliVeri());

      // Aktif filtreyi koru
      if (_ebysAktifFiltre) ebysListeFiltrele(_ebysAktifFiltre);

    } else {
      toast('❌ Hata: ' + (data.mesaj || 'Bilinmeyen hata'), 't-err');
      // Başarısız olunca disable'ı kaldır
      if (btn)  btn.disabled = false;
      if (spin) spin.classList.remove('show');
    }

  } catch(e) {
    toast('❌ Bağlantı hatası: ' + e.message, 't-err');
    if (btn)  btn.disabled = false;
    if (spin) spin.classList.remove('show');
  }
  // finally bloğu KALDIRILDI — yukarıda her dalda ayrı ayrı handle ediliyor
};

